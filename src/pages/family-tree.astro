---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Family Tree">
  <h1 class="text-2xl font-bold text-heritage-green mb-2">Family Tree</h1>
  <p class="text-heritage-charcoal/80 mb-6">
    A simple starting point for the Mattison family tree. Future versions will add an interactive,
    expandable tree.
  </p>
  <div class="bg-white rounded-lg shadow-sm p-6 text-sm text-heritage-charcoal/70">
    Family member cards and relationships coming soon.
  </div>
</BaseLayout>
