---
import BaseLayout from '../layouts/BaseLayout.astro';
import stories from '../data/stories.json';
---
<BaseLayout title="Stories & Memories">
  <h1 class="text-2xl font-bold text-heritage-green mb-2">Stories & Memories</h1>
  <p class="text-heritage-charcoal/80 mb-6">Funny stories, traditions, childhood memories, and reflections.</p>
  <div class="space-y-4">
    {stories.map((s) => (
      <div class="bg-white rounded-lg shadow-sm p-5 border-l-4 border-heritage-gold">
        <h3 class="font-bold text-heritage-charcoal">{s.title}</h3>
        <p class="text-xs text-heritage-charcoal/60 mb-1">{s.category}</p>
        <p class="text-sm text-heritage-charcoal/80">{s.summary}</p>
      </div>
    ))}
  </div>
</BaseLayout>
