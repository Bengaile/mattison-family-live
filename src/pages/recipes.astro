---
import BaseLayout from '../layouts/BaseLayout.astro';
import recipes from '../data/recipes.json';
---
<BaseLayout title="Family Recipes">
  <h1 class="text-2xl font-bold text-heritage-green mb-2">Family Recipes</h1>
  <p class="text-heritage-charcoal/80 mb-6">Dishes and traditions passed down through generations.</p>
  <div class="grid sm:grid-cols-2 gap-4">
    {recipes.map((r) => (
      <div class="bg-white rounded-lg shadow-sm p-5 border-l-4 border-heritage-orange">
        <h3 class="font-bold text-heritage-charcoal">{r.title}</h3>
        <p class="text-xs text-heritage-charcoal/60 mb-1">{r.person}</p>
        <p class="text-sm text-heritage-charcoal/80">{r.story}</p>
      </div>
    ))}
  </div>
</BaseLayout>
