---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import friends from '../data/friends.json';
---
<BaseLayout title="Dear Friends">
  <h1 class="text-2xl font-bold text-heritage-green mb-2">Dear Friends</h1>
  <p class="text-heritage-charcoal/80 mb-6">Close family friends who became family.</p>
  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
    {friends.map((friend) => (
      <ProfileCard name={friend.name} summary={friend.summary} image={friend.photos[0]} badge={friend.relationship} />
    ))}
  </div>
</BaseLayout>
