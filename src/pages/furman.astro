---
import BaseLayout from '../layouts/BaseLayout.astro';
import schools from '../data/schools.json';
const furman = schools.find(s => s.id === 'furman');
---
<BaseLayout title="Furman">
  <h1 class="text-2xl font-bold text-heritage-green mb-2">{furman?.name}</h1>
  <p class="text-heritage-charcoal/80 mb-6">{furman?.summary}</p>
  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
    {["Alumni", "Campus Memories", "Graduation Photos", "Music", "Athletics", "Favorite Professors", "Historical Photos", "Stories"].map((s) => (
      <div class="bg-white rounded-lg shadow-sm p-5 border-l-4 border-heritage-green">
        <h3 class="font-bold text-heritage-charcoal">{s}</h3>
        <p class="text-sm text-heritage-charcoal/70 mt-1">Content coming soon.</p>
      </div>
    ))}
  </div>
</BaseLayout>
