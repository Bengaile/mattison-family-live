---
import BaseLayout from '../layouts/BaseLayout.astro';
const categories = ["Family Member", "Family Pet", "Dear Friend", "Mattison Farms", "Clemson", "Furman", "Recipe", "Milestone", "Family History", "Legacy Vault", "Photo", "Video", "Document"];
---
<BaseLayout title="Upload Memories">
  <h1 class="text-2xl font-bold text-heritage-green mb-2">Upload Memories</h1>
  <p class="text-heritage-charcoal/80 mb-6">
    Share a photo, story, recipe, or memory with the rest of the family. Every contribution helps preserve our history.
  </p>

  <!-- Replace 'your-form-id' with your actual Formspree form ID -->
  <form action="https://formspree.io/f/your-form-id" method="POST" class="bg-white rounded-lg shadow-sm p-6 space-y-4 max-w-2xl">
    <div>
      <label class="block text-sm font-bold mb-1">Your Name</label>
      <input type="text" name="name" required class="w-full border rounded-md px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm font-bold mb-1">Your Email</label>
      <input type="email" name="email" required class="w-full border rounded-md px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm font-bold mb-1">Category</label>
      <select name="category" class="w-full border rounded-md px-3 py-2">
        {categories.map((c) => <option>{c}</option>)}
      </select>
    </div>
    <div>
      <label class="block text-sm font-bold mb-1">Person / Pet / Friend / Farm / School Connected</label>
      <input type="text" name="connection" class="w-full border rounded-md px-3 py-2" />
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-bold mb-1">Year / Approx. Date</label>
        <input type="text" name="year" class="w-full border rounded-md px-3 py-2" />
      </div>
      <div>
        <label class="block text-sm font-bold mb-1">Location</label>
        <input type="text" name="location" class="w-full border rounded-md px-3 py-2" />
      </div>
    </div>
    <div>
      <label class="block text-sm font-bold mb-1">People Pictured or Mentioned</label>
      <input type="text" name="people" class="w-full border rounded-md px-3 py-2" />
    </div>
    <div>
      <label class="block text-sm font-bold mb-1">Story / Description</label>
      <textarea name="story" rows="4" class="w-full border rounded-md px-3 py-2"></textarea>
    </div>
    <div>
      <label class="block text-sm font-bold mb-1">Upload File (photo, video, or document)</label>
      <input type="file" name="file" class="w-full" />
    </div>
    <div class="flex items-start gap-2">
      <input type="checkbox" name="permission" required class="mt-1" />
      <label class="text-sm">I give permission to add this memory to the family archive.</label>
    </div>
    <button type="submit" class="bg-heritage-orange text-white px-6 py-2 rounded-md hover:opacity-90">Submit Memory</button>
  </form>
</BaseLayout>
